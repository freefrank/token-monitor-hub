# Keep the worker self-contained so the "Deploy to Cloudflare" button (which
# treats this subdirectory as the new repo root) has its own ignore rules.
node_modules/
.wrangler/

# Local secrets — never commit. The committed template is .dev.vars.example.
.dev.vars
.dev.vars.*
!.dev.vars.example
.env
.env.*
!.env.example

*.log
